<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_port_airport_list" model="ir.ui.view">
        <field name="name">master.port.airport.list</field>
        <field name="model">master.port.airport</field>
        <field name="arch" type="xml">
            <list string="Ports &amp; Airports" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="type"/>
                <field name="country_id"/>
                <field name="city"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_port_airport_form" model="ir.ui.view">
        <field name="name">master.port.airport.form</field>
        <field name="model">master.port.airport</field>
        <field name="arch" type="xml">
            <form string="Port / Airport">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="country_id"/>
                            <field name="city"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_port_airport" model="ir.actions.act_window">
        <field name="name">Port &amp; Airport Management</field>
        <field name="res_model">master.port.airport</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
