    <template id="report_logistics_job_quotation_styles">
        <style type="text/css">
            .freight_forwarding-quote-letterhead { margin-bottom: 16px; }
            .freight_forwarding-quote-logo-wrap { text-align: center; margin-bottom: 10px; }
            .freight_forwarding-quote-logo { max-height: 72px; max-width: 320px; width: auto; }
            .freight_forwarding-quote-logo-fallback { font-size: 28px; font-weight: 700; letter-spacing: 1px; }
            .freight_forwarding-quote-office-table { width: 100%; border-bottom: 3px solid #de5d5d; padding-bottom: 8px; margin-bottom: 18px; }
            .freight_forwarding-quote-office-table td { width: 33.33%; vertical-align: top; padding: 0 8px; font-size: 10px; line-height: 1.35; }
            .freight_forwarding-quote-office-title { display: block; font-size: 12px; font-weight: 700; margin-bottom: 2px; }
            .freight_forwarding-quote-title { text-align: center; font-size: 22px; font-weight: 700; margin: 20px 0; }
            .freight_forwarding-quote-section { font-size: 15px; font-weight: 700; margin: 18px 0 8px; }
            .freight_forwarding-quote-table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
            .freight_forwarding-quote-table th, .freight_forwarding-quote-table td { border: 1px solid #222; padding: 4px 6px; font-size: 11px; vertical-align: top; }
            .freight_forwarding-quote-meta { width: 100%; margin-bottom: 14px; font-size: 12px; }
            .freight_forwarding-quote-meta td { padding: 2px 4px 2px 0; vertical-align: top; }
            .freight_forwarding-quote-body { font-size: 12px; margin-bottom: 12px; white-space: pre-line; }
            .freight_forwarding-quote-split { width: 100%; }
            .freight_forwarding-quote-split td { width: 50%; vertical-align: top; }
            .freight_forwarding-quote-note { margin-top: 12px; font-size: 12px; white-space: pre-line; }
            .freight_forwarding-quote-total { color: #c00000; font-weight: 700; }
            .freight_forwarding-quote-sales-label { color: #c00000; font-weight: 700; }
        </style>
    </template>

    <template id="report_logistics_job_quotation_common_header">
        <t t-set="company" t-value="o.env.company"/>
        <div class="freight_forwarding-quote-letterhead">
            <div class="freight_forwarding-quote-logo-wrap">
                <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" class="freight_forwarding-quote-logo" alt="Logo"/>
                <div t-else="" class="freight_forwarding-quote-logo-fallback">
                    <span t-out="company.name or 'Freight_Forwarding Logistics'"/>
                </div>
            </div>
            <table class="freight_forwarding-quote-office-table">
                <tr>
                    <td>
                        <span class="freight_forwarding-quote-office-title">Ho Chi Minh City Office</span>
                        <div>Address: 5th Floor, Dinh Le Building, No.1 Dinh Le Street.</div>
                        <div>13th ward, Dist 4, Ho Chi Minh City, Viet Nam.</div>
                        <div>Email: info@freight_forwarding.com.vn Tel: +84-28 38 267 292 Fax: +84-28 39435532</div>
                    </td>
                    <td>
                        <span class="freight_forwarding-quote-office-title">Da Nang City - Rep.Office</span>
                        <div>Address: 606B Room, 6th Floor, One Opera Building,</div>
                        <div>115 Nguyen Van Linh Street, Hai Chau Dist, Da Nang City, Viet Nam.</div>
                        <div>Tel: +84-236 384 3399 Fax: +84-28 39435532</div>
                    </td>
                    <td>
                        <span class="freight_forwarding-quote-office-title">Ha Noi City - Rep.Office</span>
                        <div>Address: Room 2B2, 2 Floor, Hoang Cau Building,</div>
                        <div>71 Hoang Cau Street, O Cho Dua Ward, Ha Noi City, Viet Nam.</div>
                        <div>Tel: +84-24 32 17 17 10 Fax: +84-24 32 17 17 11</div>
                    </td>
                </tr>
            </table>
        </div>
        <table class="freight_forwarding-quote-meta">
            <tr>
                <td><strong>Subject :</strong></td>
                <td><span t-out="o.subject or ''"/></td>
            </tr>
            <tr>
                <td><strong>To :</strong></td>
                <td><span t-out="o.attention_to or o.customer_id.name or ''"/></td>
            </tr>
            <tr>
                <td><strong>PIC :</strong></td>
                <td><span t-out="o.pic_name or ''"/></td>
            </tr>
            <tr>
                <td><strong>Valid to :</strong></td>
                <td><span t-field="o.valid_until"/></td>
            </tr>
        </table>

        <div class="freight_forwarding-quote-title">
            <span t-out="o._get_quotation_title()"/>
        </div>

        <div class="freight_forwarding-quote-body">
            <span t-out="o._get_quotation_intro_text()"/>
        </div>

        <t t-if="o.commodity or o.routing_summary or o.volume_summary">
            <table class="freight_forwarding-quote-meta" style="margin-bottom: 10px;">
                <tr t-if="o.commodity">
                    <td style="width: 18%;"><strong>Commodity</strong></td>
                    <td><span t-out="o.commodity"/></td>
                </tr>
                <tr t-if="o.routing_summary">
                    <td><strong>Routing</strong></td>
                    <td><span t-out="o.routing_summary"/></td>
                </tr>
                <tr t-if="o.volume_summary">
                    <td><strong>Volume</strong></td>
                    <td><span t-out="o.volume_summary"/></td>
                </tr>
            </table>
        </t>
    </template>

    <template id="report_logistics_job_quotation_common_footer">
        <div class="freight_forwarding-quote-note">
            <strong>Note :</strong>
            <span t-out="o._get_quotation_footer_text()"/>
        </div>
        <p style="font-size: 12px; margin-top: 14px;">
            We do hope that the above match your inquiry. For further info, please do not hesitate to contact us at anytime.
        </p>
        <p style="font-size: 12px; margin-top: 16px;">
            Many thanks and best regards.
        </p>
        <p style="font-size: 12px; margin-top: 16px;">
            <span class="freight_forwarding-quote-sales-label">Full name of salesman:</span>
            <strong><span t-out="o._get_salesperson_name()"/></strong><br/>
            Email: <span t-out="o._get_salesperson_email()"/><br/>
            Hand phone: <span t-out="o._get_salesperson_phone()"/>
        </p>
    </template>

    <template id="report_logistics_job_quotation_trucking_customs">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <t t-call="freight_forwarding_freight.report_logistics_job_quotation_styles"/>
                        <t t-call="freight_forwarding_freight.report_logistics_job_quotation_common_header"/>

                        <t t-set="truck_lines" t-value="o._get_quote_rate_lines('truck_rate')"/>
                        <div class="freight_forwarding-quote-section">1. Trucking fee</div>
                        <table class="freight_forwarding-quote-table">
                            <thead>
                                <tr>
                                    <th>Port or airport</th>
                                    <th>Destination</th>
                                    <th>Truck 1.5 tons</th>
                                    <th>Truck 3.5 tons</th>
                                    <th>Truck 5 tons</th>
                                    <th>20 DC</th>
                                    <th>40 DC</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="truck_lines" t-as="line">
                                    <td><span t-out="line.name or ''"/></td>
                                    <td><span t-out="line.destination_code or ''"/></td>
                                    <td><span t-field="line.amount_1"/></td>
                                    <td><span t-field="line.amount_2"/></td>
                                    <td><span t-field="line.amount_3"/></td>
                                    <td><span t-field="line.amount_4"/></td>
                                    <td><span t-field="line.amount_5"/></td>
                                </tr>
                                <tr t-if="not truck_lines">
                                    <td colspan="7">&#160;</td>
                                </tr>
                            </tbody>
                        </table>

                        <t t-set="customs_import_lines" t-value="o._get_quote_rate_lines('customs_import')"/>
                        <div class="freight_forwarding-quote-section">2. Customs fee for import shipment</div>
                        <table class="freight_forwarding-quote-table">
                            <thead>
                                <tr>
                                    <th>Types of import</th>
                                    <th>Destination</th>
                                    <th>1 - 3 cbms</th>
                                    <th>3 - 5 cbms</th>
                                    <th>5 - 10 cbms</th>
                                    <th>20 DC</th>
                                    <th>40 DC</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="customs_import_lines" t-as="line">
                                    <td><span t-out="line.name or ''"/></td>
                                    <td><span t-out="line.destination_code or ''"/></td>
                                    <td><span t-field="line.amount_1"/></td>
                                    <td><span t-field="line.amount_2"/></td>
                                    <td><span t-field="line.amount_3"/></td>
                                    <td><span t-field="line.amount_4"/></td>
                                    <td><span t-field="line.amount_5"/></td>
                                </tr>
                                <tr t-if="not customs_import_lines">
                                    <td colspan="7">&#160;</td>
                                </tr>
                            </tbody>
                        </table>

                        <t t-set="customs_export_lines" t-value="o._get_quote_rate_lines('customs_export')"/>
                        <div class="freight_forwarding-quote-section">3. Customs fee for export shipment</div>
                        <table class="freight_forwarding-quote-table">
                            <thead>
                                <tr>
                                    <th>Types</th>
                                    <th>Clients</th>
                                    <th>1 - 3 cbms</th>
                                    <th>3 - 5 cbms</th>
                                    <th>5 - 10 cbms</th>
                                    <th>20 DC</th>
                                    <th>40 DC</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="customs_export_lines" t-as="line">
                                    <td><span t-out="line.name or ''"/></td>
                                    <td><span t-out="line.carrier_or_party or ''"/></td>
                                    <td><span t-field="line.amount_1"/></td>
                                    <td><span t-field="line.amount_2"/></td>
                                    <td><span t-field="line.amount_3"/></td>
                                    <td><span t-field="line.amount_4"/></td>
                                    <td><span t-field="line.amount_5"/></td>
                                </tr>
                                <tr t-if="not customs_export_lines">
                                    <td colspan="7">&#160;</td>
                                </tr>
                            </tbody>
                        </table>

                        <t t-call="freight_forwarding_freight.report_logistics_job_quotation_common_footer"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

