<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_freight_forwarding_freight" model="ir.ui.view">
        <field name="name">sale.order.form.freight_forwarding.freight</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Replace the standard title/customer block with our freight layout -->
            <xpath expr="//div[hasclass('oe_title')]" position="replace">
                <div class="d-flex justify-content-between align-items-start flex-wrap mb-2 w-100">
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <div class="text-muted small">
                            Lead: <field name="opportunity_id" class="oe_inline"
                                         options="{'no_create': True}"/>
                        </div>
                    </div>
                    <div class="d-flex flex-column gap-2 mt-1">
                        <div class="d-flex align-items-center gap-2">
                            <label for="currency_id" string="Currency:" class="fw-bold text-nowrap mb-0"/>
                            <field name="currency_id" options="{'no_create': True, 'no_open': True}" class="w-auto"/>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="fw-bold">Stage:</span>
                            <field name="opportunity_id" string="Stage" readonly="1" class="w-auto"
                                   invisible="not opportunity_id"/>
                        </div>
                    </div>
                </div>
            </xpath>

            <!-- Replace the partner/date group with our Shipment + Client Details -->
            <xpath expr="//group[@name='sale_header']" position="replace">
                <group>
                    <group string="Shipment Details">
                        <field name="validity_date" string="Expiration"/>
                        <field name="date_order" string="Quotation Date"/>
                    </group>
                    <group string="Client Details">
                        <field name="partner_id" string="Customer Name"
                               options="{'no_create_edit': True}"/>
                        <field name="partner_invoice_id" invisible="1"/>
                        <field name="partner_shipping_id" invisible="1"/>
                        <field name="payment_term_id" string="Payment Terms" invisible="1"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>
</odoo>
