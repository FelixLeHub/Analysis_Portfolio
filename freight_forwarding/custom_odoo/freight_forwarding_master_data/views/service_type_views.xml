<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_service_type_list" model="ir.ui.view">
        <field name="name">master.service.type.list</field>
        <field name="model">master.service.type</field>
        <field name="arch" type="xml">
            <list string="Service Types" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_service_type" model="ir.actions.act_window">
        <field name="name">Service Type</field>
        <field name="res_model">master.service.type</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
