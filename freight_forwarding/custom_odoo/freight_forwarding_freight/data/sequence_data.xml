<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_logistics_job" model="ir.sequence">
            <field name="name">Logistics Job</field>
            <field name="code">logistics.job</field>
            <field name="prefix">JOB/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
        </record>

        <record id="seq_customer_debit_note" model="ir.sequence">
            <field name="name">Customer Debit Note</field>
            <field name="code">logistics.customer.debit.note</field>
            <field name="prefix">INV%(year)s%(month)s/</field>
            <field name="padding">3</field>
        </record>
    </data>
</odoo>
