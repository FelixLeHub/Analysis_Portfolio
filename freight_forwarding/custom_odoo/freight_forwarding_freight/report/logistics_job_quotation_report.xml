                        <table class="freight_forwarding-quote-table">
                            <thead>
                                <tr>
                                    <th>Ex-work charge at POL</th>
                                    <th>Unit</th>
                                    <th>Amount</th>
                                    <th>Remark</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="air_exwork_lines" t-as="line">
                                    <td><span t-out="line.name or ''"/></td>
                                    <td><span t-out="line.unit_description or ''"/></td>
                                    <td><span t-field="line.amount"/></td>
                                    <td><span t-out="line.remark or ''"/></td>
                                </tr>
                                <tr t-if="not air_exwork_lines">
                                    <td colspan="4">&#160;</td>
                                </tr>
                            </tbody>
                        </table>

                        <t t-set="air_local_lines" t-value="o._get_quote_charge_lines('air_local')"/>
                        <div class="freight_forwarding-quote-section">3. Local charge at the airport of delivery</div>
                        <table class="freight_forwarding-quote-table">
                            <thead>
                                <tr>
                                    <th>Charge</th>
                                    <th>Amount</th>
                                    <th>Remark</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="air_local_lines" t-as="line">
                                    <td><span t-out="line.name or ''"/></td>
                                    <td><span t-field="line.amount"/></td>
                                    <td><span t-out="line.remark or ''"/></td>
                                </tr>
                                <tr t-if="not air_local_lines">
                                    <td colspan="3">&#160;</td>
                                </tr>
                            </tbody>
                        </table>

                        <t t-call="freight_forwarding_freight.report_logistics_job_quotation_common_footer"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
