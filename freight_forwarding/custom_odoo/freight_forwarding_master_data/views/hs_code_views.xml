<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hs_code_list" model="ir.ui.view">
        <field name="name">master.hs.code.list</field>
        <field name="model">master.hs.code</field>
        <field name="arch" type="xml">
            <list string="HS Codes" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="chapter"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_hs_code_form" model="ir.ui.view">
        <field name="name">master.hs.code.form</field>
        <field name="model">master.hs.code</field>
        <field name="arch" type="xml">
            <form string="HS Code">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="chapter"/>
                        </group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hs_code" model="ir.actions.act_window">
        <field name="name">HS Code Management</field>
        <field name="res_model">master.hs.code</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
